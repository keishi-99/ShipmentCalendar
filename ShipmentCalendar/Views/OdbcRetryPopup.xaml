<Window x:Class="ShipmentCalendar.Views.OdbcRetryPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="データ取得リトライ" Height="160" Width="380"
        WindowStyle="ToolWindow" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <DockPanel Margin="16">
        <Button Name="BtnCancel" DockPanel.Dock="Bottom" Content="キャンセル" Padding="16,4"
                HorizontalAlignment="Center" Margin="0,12,0,0" Click="BtnCancel_Click"/>
        <TextBlock Name="TxtMessage" TextWrapping="Wrap" FontSize="13"
                    VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
    </DockPanel>
</Window>
