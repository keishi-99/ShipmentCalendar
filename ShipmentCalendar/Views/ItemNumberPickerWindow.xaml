<Window
    x:Class="ShipmentCalendar.Views.ItemNumberPickerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="品目番号を選択"
    Width="420"
    Height="520"
    WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <!--  検索ボックス  -->
        <TextBox
            Name="TxtSearch"
            Margin="0,0,0,8"
            Padding="6,4"
            DockPanel.Dock="Top"
            TextChanged="TxtSearch_TextChanged"
            VerticalContentAlignment="Center" />

        <!--  ボタン  -->
        <StackPanel
            Margin="0,8,0,0"
            HorizontalAlignment="Right"
            DockPanel.Dock="Bottom"
            Orientation="Horizontal">
            <Button
                Margin="0,0,8,0"
                Padding="16,6"
                Background="#1976D2"
                BorderThickness="0"
                Click="BtnSelect_Click"
                Content="選択"
                Foreground="White" />
            <Button
                Padding="16,6"
                Click="BtnCancel_Click"
                Content="キャンセル" />
        </StackPanel>

        <!--  品目一覧（品目番号・品目名を列で表示）  -->
        <ListView
            Name="LstItems"
            MouseDoubleClick="LstItems_MouseDoubleClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="120" Header="品目番号" DisplayMemberBinding="{Binding ItemNumber}" />
                    <GridViewColumn Width="220" Header="品目名" DisplayMemberBinding="{Binding DisplayName}" />
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</Window>
