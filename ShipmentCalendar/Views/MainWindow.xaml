<Window
    x:Class="ShipmentCalendar.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="clr-namespace:ShipmentCalendar.Models"
    xmlns:views="clr-namespace:ShipmentCalendar.Views"
    Title="出荷カレンダー"
    Width="1500"
    Height="700"
    WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!--  工程ステータスによる色分けコンバーター  -->
        <Style x:Key="ProcessCellStyle" TargetType="TextBlock">
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <views:InverseBooleanConverter x:Key="InverseBool" />
        <!--  固定列のセル内テキストを縦中央に揃えるスタイル  -->
        <Style x:Key="FixedColumnCellStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <!--  ルートを Grid にして DockPanel の上にスピナーオーバーレイを重ねる  -->
    <Grid>
        <DockPanel>
            <!--  ツールバー  -->
            <ToolBar Background="#1976D2" DockPanel.Dock="Top">
                <ToolBar.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Padding" Value="8,4" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="FontSize" Value="14" />
                        <Setter Property="Foreground" Value="White" />
                    </Style>
                </ToolBar.Resources>
                <Button Command="{Binding LoadOrdersCommand}">
                    更新
                </Button>
                <Separator />
                <!--  設定系をまとめたドロップダウンメニュー  -->
                <Menu VerticalAlignment="Center" Background="Transparent">
                    <MenuItem
                        Padding="8,4"
                        Background="Transparent"
                        FontSize="14"
                        Foreground="White">
                        <MenuItem.Header>設定 ▾</MenuItem.Header>
                        <MenuItem Click="BtnSettings_Click" Header="データソース設定" />
                        <MenuItem Click="BtnProcess_Click" Header="工程設定" />
                        <MenuItem Click="BtnHoliday_Click" Header="休日設定" />
                        <MenuItem Click="BtnDeptSetting_Click" Header="部署設定" />
                        <MenuItem Click="BtnDisplaySettings_Click" Header="表示設定" />
                        <Separator />
                        <MenuItem Header="列の表示設定">
                            <MenuItem Name="MnuColDeliveryDate" IsCheckable="True" StaysOpenOnClick="True" Header="出荷日" Checked="ColumnVisibilityCheckBox_Changed" Unchecked="ColumnVisibilityCheckBox_Changed" />
                            <MenuItem Name="MnuColCompletionDate" IsCheckable="True" StaysOpenOnClick="True" Header="完了日" Checked="ColumnVisibilityCheckBox_Changed" Unchecked="ColumnVisibilityCheckBox_Changed" />
                            <MenuItem Name="MnuColItemNumber" IsCheckable="True" StaysOpenOnClick="True" Header="品目番号" Checked="ColumnVisibilityCheckBox_Changed" Unchecked="ColumnVisibilityCheckBox_Changed" />
                            <MenuItem Name="MnuColModelCode" IsCheckable="True" StaysOpenOnClick="True" Header="機種コード" Checked="ColumnVisibilityCheckBox_Changed" Unchecked="ColumnVisibilityCheckBox_Changed" />
                            <MenuItem Name="MnuColProductName" IsCheckable="True" StaysOpenOnClick="True" Header="品目名" Checked="ColumnVisibilityCheckBox_Changed" Unchecked="ColumnVisibilityCheckBox_Changed" />
                            <MenuItem Name="MnuColManufactureNumber" IsCheckable="True" StaysOpenOnClick="True" Header="製番" Checked="ColumnVisibilityCheckBox_Changed" Unchecked="ColumnVisibilityCheckBox_Changed" />
                            <MenuItem Name="MnuColPlannedQuantity" IsCheckable="True" StaysOpenOnClick="True" Header="計画数" Checked="ColumnVisibilityCheckBox_Changed" Unchecked="ColumnVisibilityCheckBox_Changed" />
                        </MenuItem>
                    </MenuItem>
                </Menu>
                <Separator />
                <!--  注文一覧の並び順切り替え（出荷日順/工程期限順）  -->
                <Button Name="BtnToggleSortMode" Click="BtnToggleSortMode_Click" />
                <!--  未完了工程の表示日切り替え（クリックで着手必須日/完了必須日を切り替え）  -->
                <Button Name="BtnToggleDueDateDisplay" Click="BtnToggleDueDateDisplay_Click" />
                <!--  工程表示モード切り替え（バー/リスト）  -->
                <Button Name="BtnToggleProcessMode" Click="BtnToggleProcessMode_Click" />
                <Separator />
                <!--  クイックフィルター（超過・警告・今日対応）  -->
                <ToggleButton
                    Margin="2,0"
                    Padding="10,4"
                    BorderThickness="0"
                    Content="超過"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="White"
                    IsChecked="{Binding FilterOverdueOnly}">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Background" Value="#B71C1C" />
                                    <Setter Property="BorderThickness" Value="0,0,0,3" />
                                    <Setter Property="BorderBrush" Value="White" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#C62828" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>
                <ToggleButton
                    Margin="2,0"
                    Padding="10,4"
                    BorderThickness="0"
                    Content="警告"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="White"
                    IsChecked="{Binding FilterWarningOnly}">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Background" Value="#E65100" />
                                    <Setter Property="BorderThickness" Value="0,0,0,3" />
                                    <Setter Property="BorderBrush" Value="White" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EF6C00" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>
                <ToggleButton
                    Margin="2,0"
                    Padding="10,4"
                    BorderThickness="0"
                    Content="進行中"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="White"
                    IsChecked="{Binding FilterTodayTask}">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Background" Value="#0D47A1" />
                                    <Setter Property="BorderThickness" Value="0,0,0,3" />
                                    <Setter Property="BorderBrush" Value="White" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1565C0" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>
                <Separator />
                <!--  担当部署フィルターボタン（動的生成）  -->
                <ItemsControl ItemsSource="{Binding DepartmentFilters}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ToggleButton
                                Margin="2,0"
                                Padding="10,4"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding DataContext.SelectDepartmentCommand, RelativeSource={RelativeSource AncestorType=ToolBar}}"
                                CommandParameter="{Binding Id}"
                                Content="{Binding Name}"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="White"
                                IsChecked="{Binding IsSelected, Mode=OneWay}">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="Foreground" Value="White" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Style.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter Property="Background" Value="#0D47A1" />
                                                <Setter Property="BorderThickness" Value="0,0,0,3" />
                                                <Setter Property="BorderBrush" Value="White" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1565C0" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Separator />
                <!--  フルスクリーン表示の切り替え（F11キーと同じ動作）  -->
                <Button Name="BtnToggleFullScreen" Click="BtnToggleFullScreen_Click">
                    フルスクリーン
                </Button>
            </ToolBar>

            <!--  フィルターバー  -->
            <StackPanel
                Margin="4,4,4,2"
                Background="#F0F4F8"
                DockPanel.Dock="Top"
                Orientation="Horizontal">
                <TextBlock
                    Margin="6,0,2,0"
                    VerticalAlignment="Center"
                    Text="出荷日：" />
                <DatePicker
                    Width="112"
                    Margin="0,0,2,0"
                    DisplayDateEnd="{Binding FilterDateMax}"
                    DisplayDateStart="{Binding FilterDateMin}"
                    IsEnabled="{Binding FilterTodayOnly, Converter={StaticResource InverseBool}}"
                    SelectedDate="{Binding FilterDeliveryFrom}" />
                <TextBlock
                    Margin="0,0,2,0"
                    VerticalAlignment="Center"
                    Text="〜" />
                <DatePicker
                    Width="112"
                    Margin="0,0,4,0"
                    DisplayDateEnd="{Binding FilterDateMax}"
                    DisplayDateStart="{Binding FilterDateMin}"
                    IsEnabled="{Binding FilterTodayOnly, Converter={StaticResource InverseBool}}"
                    SelectedDate="{Binding FilterDeliveryTo}" />
                <CheckBox
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    Content="本日のみ"
                    IsChecked="{Binding FilterTodayOnly}" />
                <TextBlock
                    Margin="0,0,2,0"
                    VerticalAlignment="Center"
                    Text="品目番号：" />
                <TextBox
                    Width="130"
                    Margin="0,0,10,0"
                    Padding="3,2"
                    VerticalContentAlignment="Center"
                    Text="{Binding FilterItemNumber, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock
                    Margin="0,0,2,0"
                    VerticalAlignment="Center"
                    Text="品目名：" />
                <TextBox
                    Width="130"
                    Margin="0,0,10,0"
                    Padding="3,2"
                    VerticalContentAlignment="Center"
                    Text="{Binding FilterProductName, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock
                    Margin="0,0,2,0"
                    VerticalAlignment="Center"
                    Text="製番：" />
                <TextBox
                    Width="140"
                    Margin="0,0,10,0"
                    Padding="3,2"
                    VerticalContentAlignment="Center"
                    Text="{Binding FilterManufactureNumber, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock
                    Margin="0,0,2,0"
                    VerticalAlignment="Center"
                    Text="区分：" />
                <ComboBox
                    Width="120"
                    Margin="0,0,10,0"
                    ItemsSource="{Binding ProductCategoryOptions}"
                    SelectedItem="{Binding FilterProductCategory}" />
                <CheckBox
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    Content="完了済みを非表示"
                    IsChecked="{Binding FilterHideCompleted}" />
                <Button
                    Padding="8,3"
                    Click="BtnClearFilter_Click"
                    Content="クリア" />
            </StackPanel>

            <!--  ステータスバー（左：状態メッセージ、右：凡例）  -->
            <StatusBar Background="#EEEEEE" DockPanel.Dock="Bottom">
                <StatusBarItem DockPanel.Dock="Right">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Text="凡例：" />
                        <Border
                            Width="80"
                            Height="20"
                            Margin="2"
                            Background="{StaticResource StatusNotStarted}"
                            CornerRadius="3">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Text="未着手" />
                        </Border>
                        <Border
                            Width="80"
                            Height="20"
                            Margin="2"
                            Background="{StaticResource StatusInProgress}"
                            CornerRadius="3">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Text="進行中" />
                        </Border>
                        <Border
                            Width="80"
                            Height="20"
                            Margin="2"
                            Background="#FF9800"
                            CornerRadius="3">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Text="警告" />
                        </Border>
                        <Border
                            Width="80"
                            Height="20"
                            Margin="2"
                            Background="{StaticResource StatusCompleted}"
                            CornerRadius="3">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Text="完了" />
                        </Border>
                        <Border
                            Width="80"
                            Height="20"
                            Margin="2"
                            Background="{StaticResource StatusOverdue}"
                            CornerRadius="3">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="White"
                                Text="超過" />
                        </Border>
                        <Border
                            Width="80"
                            Height="20"
                            Margin="2"
                            Background="{StaticResource DwellTimeBrush}"
                            CornerRadius="3">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Text="滞留時間" />
                        </Border>
                        <Border
                            Width="80"
                            Height="20"
                            Margin="2"
                            Background="{StaticResource OutsourceLeadBrush}"
                            CornerRadius="3">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Text="外注待ち" />
                        </Border>
                    </StackPanel>
                </StatusBarItem>
                <StatusBarItem>
                    <TextBlock Padding="4" Text="{Binding StatusMessage}" />
                </StatusBarItem>
            </StatusBar>

            <!--  メインリスト  -->
            <DataGrid
                Name="OrderGrid"
                Margin="4"
                AlternatingRowBackground="#F5F5F5"
                AutoGenerateColumns="False"
                CanUserSortColumns="False"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                IsReadOnly="True"
                ItemsSource="{Binding Orders}"
SelectionMode="Single"
                SelectionUnit="Cell">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        x:Name="ColDeliveryDate"
                        Width="100"
                        Binding="{Binding DeliveryDate, StringFormat=yyyy/MM/dd}"
                        ElementStyle="{StaticResource FixedColumnCellStyle}"
                        Header="出荷日" />
                    <DataGridTextColumn
                        x:Name="ColCompletionDate"
                        Width="100"
                        Binding="{Binding CompletionDate, StringFormat=yyyy/MM/dd}"
                        ElementStyle="{StaticResource FixedColumnCellStyle}"
                        Header="完了日" />
                    <DataGridTextColumn
                        x:Name="ColItemNumber"
                        Width="150"
                        Binding="{Binding ItemNumber}"
                        ElementStyle="{StaticResource FixedColumnCellStyle}"
                        Header="品目番号" />
                    <DataGridTextColumn
                        x:Name="ColModelCode"
                        Width="100"
                        Binding="{Binding ModelCode}"
                        ElementStyle="{StaticResource FixedColumnCellStyle}"
                        Header="機種コード" />
                    <DataGridTextColumn
                        x:Name="ColProductName"
                        Width="200"
                        Binding="{Binding ProductName}"
                        ElementStyle="{StaticResource FixedColumnCellStyle}"
                        Header="品目名" />
                    <DataGridTextColumn
                        x:Name="ColManufactureNumber"
                        Width="180"
                        Binding="{Binding ManufactureNumber}"
                        ElementStyle="{StaticResource FixedColumnCellStyle}"
                        Header="製番" />
                    <DataGridTextColumn
                        x:Name="ColPlannedQuantity"
                        Width="70"
                        Binding="{Binding PlannedQuantity}"
                        ElementStyle="{StaticResource FixedColumnCellStyle}"
                        Header="計画数" />
                    <!--  工程列はコードビハインドで動的生成  -->
                </DataGrid.Columns>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <EventSetter Event="MouseDoubleClick" Handler="OrderRow_DoubleClick" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAllCompleted}" Value="True">
                                <Setter Property="Foreground" Value="#1976D2" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding HasOverdue}" Value="True">
                                <Setter Property="Foreground" Value="#E53935" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </DockPanel>

        <!--  ローディングオーバーレイ（IsLoading=true のとき表示）  -->
        <Grid IsHitTestVisible="{Binding IsLoading}">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Opacity" Value="0" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                            <Setter Property="Opacity" Value="1" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <!--  半透明の暗幕  -->
            <Rectangle Fill="#88000000" />

            <!--  スピナーカード  -->
            <Border
                Width="140"
                Height="110"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                CornerRadius="10">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="16"
                        Opacity="0.3"
                        ShadowDepth="0" />
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!--  回転する破線の楕円でスピナーを表現  -->
                    <Ellipse
                        Width="40"
                        Height="40"
                        RenderTransformOrigin="0.5,0.5"
                        Stroke="#1976D2"
                        StrokeDashArray="6 3"
                        StrokeThickness="4">
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="SpinnerRotate" />
                        </Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetName="SpinnerRotate"
                                            Storyboard.TargetProperty="Angle"
                                            From="0"
                                            To="360"
                                            Duration="0:0:0.8" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <TextBlock
                        Margin="0,10,0,0"
                        HorizontalAlignment="Center"
                        FontSize="13"
                        Foreground="#444444"
                        Text="読み込み中..." />
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>
