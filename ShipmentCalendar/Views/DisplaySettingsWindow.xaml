<Window x:Class="ShipmentCalendar.Views.DisplaySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="表示設定" Height="240" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="保存して閉じる" Padding="16,6" Background="#1976D2" Foreground="White"
                    BorderThickness="0" Click="BtnSave_Click" Margin="0,0,8,0"/>
            <Button Content="キャンセル" Padding="16,6" Click="BtnCancel_Click"/>
        </StackPanel>

        <TextBlock DockPanel.Dock="Top" FontSize="16" FontWeight="Bold"
                   Text="表示設定" Margin="0,0,0,16"/>

        <Grid DockPanel.Dock="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 固定列フォントサイズ -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="固定列のフォントサイズ："
                       VerticalAlignment="Center" Margin="0,0,0,12"/>
            <TextBox Grid.Row="0" Grid.Column="1" Name="TxtFixedColumnFontSize"
                     Width="60" HorizontalAlignment="Left"
                     VerticalContentAlignment="Center" Padding="4" Margin="0,0,0,12"/>

            <!-- 工程列：期限日表示 -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="工程列に期限日を表示："
                       VerticalAlignment="Center" Margin="0,0,0,12"/>
            <CheckBox Grid.Row="1" Grid.Column="1" Name="ChkShowProcessDate"
                      VerticalAlignment="Center" Margin="0,0,0,12"/>

            <!-- 工程列：標準時間表示 -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="工程列に標準時間を表示："
                       VerticalAlignment="Center"/>
            <CheckBox Grid.Row="2" Grid.Column="1" Name="ChkShowProcessRequiredHours"
                      VerticalAlignment="Center"/>
        </Grid>
    </DockPanel>
</Window>
