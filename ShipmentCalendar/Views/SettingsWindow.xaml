<Window x:Class="ShipmentCalendar.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定" Height="620" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="保存して閉じる" Padding="16,6" Background="#1976D2" Foreground="White"
                    BorderThickness="0" Click="BtnSave_Click" Margin="0,0,8,0"/>
            <Button Content="キャンセル" Padding="16,6" Click="BtnCancel_Click"/>
        </StackPanel>
        <TextBlock Name="TxtConnectionStatus" DockPanel.Dock="Bottom" Margin="0,8,0,0"
                   FontSize="12" Foreground="#1976D2"/>

        <TextBlock DockPanel.Dock="Top" FontSize="16" FontWeight="Bold"
                   Text="データソース設定" Margin="0,0,0,16"/>

        <Grid DockPanel.Dock="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 接続方式 -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="接続方式：" VerticalAlignment="Center" Margin="0,0,0,12"/>
            <StackPanel Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,12">
                <RadioButton Name="RbModeDsn" Content="DSNを使用" GroupName="OdbcMode"
                              IsChecked="True" Checked="RbMode_Checked" VerticalAlignment="Center"/>
                <RadioButton Name="RbModeDirect" Content="サーバーに直接接続（DSNレス）" GroupName="OdbcMode"
                              Checked="RbMode_Checked" VerticalAlignment="Center" Margin="16,0,0,0"/>
            </StackPanel>

            <!-- ODBC DSN -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="ODBC DSN名：" VerticalAlignment="Center" Margin="0,0,0,12"/>
            <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Name="TxtOdbcDsn"
                     VerticalContentAlignment="Center" Padding="4" Margin="0,0,0,12"
                     ToolTip="例: DrSum_WORKDB_YD"/>

            <!-- サーバー -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="サーバー：" VerticalAlignment="Center" Margin="0,0,0,12"/>
            <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Name="TxtOdbcServer"
                     VerticalContentAlignment="Center" Padding="4" Margin="0,0,0,12"
                     ToolTip="例: 192.168.1.10"/>

            <!-- ポート -->
            <TextBlock Grid.Row="3" Grid.Column="0" Text="ポート：" VerticalAlignment="Center" Margin="0,0,0,12"/>
            <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Name="TxtOdbcPort"
                     VerticalContentAlignment="Center" Padding="4" Margin="0,0,0,12"
                     ToolTip="例: 6001"/>

            <!-- データベース名 -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="データベース名：" VerticalAlignment="Center" Margin="0,0,0,12"/>
            <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Name="TxtOdbcDatabase"
                     VerticalContentAlignment="Center" Padding="4" Margin="0,0,0,12"/>

            <!-- ユーザーID -->
            <TextBlock Grid.Row="5" Grid.Column="0" Text="ユーザーID：" VerticalAlignment="Center" Margin="0,0,0,12"/>
            <TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Name="TxtOdbcUserId"
                     VerticalContentAlignment="Center" Padding="4" Margin="0,0,0,12"/>

            <!-- パスワード -->
            <TextBlock Grid.Row="6" Grid.Column="0" Text="パスワード：" VerticalAlignment="Center" Margin="0,0,0,12"/>
            <PasswordBox Grid.Row="6" Grid.Column="1" Name="PwdOdbcPassword"
                         Padding="4" Margin="0,0,4,12"/>
            <Button Grid.Row="6" Grid.Column="2" Content="接続テスト" Padding="8,4" Margin="0,0,0,12"
                    Click="BtnTestConnection_Click"/>

            <Separator Grid.Row="7" Grid.ColumnSpan="3" Margin="0,4"/>

            <TextBlock Grid.Row="8" Grid.Column="0" Text="自動更新間隔（分）：" VerticalAlignment="Center" Margin="0,0,0,12"/>
            <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12">
                <TextBox Name="TxtRefreshMinutes" Width="60" VerticalContentAlignment="Center" Padding="4"/>
                <TextBlock Text="　※ 0 で自動更新なし" VerticalAlignment="Center" Foreground="#888" Margin="8,0,0,0"/>
            </StackPanel>

            <TextBlock Grid.Row="9" Grid.Column="0" Text="過去の表示範囲（日）：" VerticalAlignment="Center" Margin="0,0,0,12"/>
            <StackPanel Grid.Row="9" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12">
                <TextBox Name="TxtPastDays" Width="60" VerticalContentAlignment="Center" Padding="4"/>
                <TextBlock Text="　※ 今日から何日前まで表示するか" VerticalAlignment="Center" Foreground="#888" Margin="8,0,0,0"/>
            </StackPanel>

            <TextBlock Grid.Row="10" Grid.Column="0" Text="未来の表示範囲（日）：" VerticalAlignment="Center" Margin="0,0,0,12"/>
            <StackPanel Grid.Row="10" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12">
                <TextBox Name="TxtRangeDays" Width="60" VerticalContentAlignment="Center" Padding="4"/>
                <TextBlock Text="　※ 今日から何日先まで表示するか" VerticalAlignment="Center" Foreground="#888" Margin="8,0,0,0"/>
            </StackPanel>

            <TextBlock Grid.Row="11" Grid.Column="0" Text="完了日までの営業日数：" VerticalAlignment="Center"/>
            <StackPanel Grid.Row="11" Grid.Column="1" Orientation="Horizontal">
                <TextBox Name="TxtCompletionLeadDays" Width="60" VerticalContentAlignment="Center" Padding="4"/>
                <TextBlock Text="　※ 出荷日の何営業日前を完了日とするか" VerticalAlignment="Center" Foreground="#888" Margin="8,0,0,0"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
