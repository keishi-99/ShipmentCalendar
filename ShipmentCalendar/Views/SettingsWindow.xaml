<Window x:Class="ShipmentCalendar.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定" Height="520" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="保存して閉じる" Padding="16,6" Background="#1976D2" Foreground="White"
                    BorderThickness="0" Click="BtnSave_Click" Margin="0,0,8,0"/>
            <Button Content="キャンセル" Padding="16,6" Click="BtnCancel_Click"/>
        </StackPanel>
        <TextBlock Name="TxtConnectionStatus" DockPanel.Dock="Bottom" Margin="0,8,0,0"
                   FontSize="12" Foreground="#1976D2"/>

        <TextBlock DockPanel.Dock="Top" FontSize="16" FontWeight="Bold"
                   Text="データソース設定" Margin="0,0,0,16"/>

        <Grid DockPanel.Dock="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- ODBC DSN -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="ODBC DSN名：" VerticalAlignment="Center" Margin="0,0,0,12"/>
            <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Name="TxtOdbcDsn"
                     VerticalContentAlignment="Center" Padding="4" Margin="0,0,0,12"
                     ToolTip="例: DrSum_WORKDB_YD"/>

            <!-- ユーザーID -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="ユーザーID：" VerticalAlignment="Center" Margin="0,0,0,12"/>
            <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Name="TxtOdbcUserId"
                     VerticalContentAlignment="Center" Padding="4" Margin="0,0,0,12"/>

            <!-- パスワード -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="パスワード：" VerticalAlignment="Center" Margin="0,0,0,12"/>
            <PasswordBox Grid.Row="2" Grid.Column="1" Name="PwdOdbcPassword"
                         Padding="4" Margin="0,0,4,12"/>
            <Button Grid.Row="2" Grid.Column="2" Content="接続テスト" Padding="8,4" Margin="0,0,0,12"
                    Click="BtnTestConnection_Click"/>

            <Separator Grid.Row="3" Grid.ColumnSpan="3" Margin="0,4"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="自動更新間隔（分）：" VerticalAlignment="Center" Margin="0,0,0,12"/>
            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12">
                <TextBox Name="TxtRefreshMinutes" Width="60" VerticalContentAlignment="Center" Padding="4"/>
                <TextBlock Text="　※ 0 で自動更新なし" VerticalAlignment="Center" Foreground="#888" Margin="8,0,0,0"/>
            </StackPanel>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="納期日の表示範囲：&#x0a;（過去側）" VerticalAlignment="Center" Margin="0,0,0,12"/>
            <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12">
                <TextBox Name="TxtPastDays" Width="60" VerticalContentAlignment="Center" Padding="4"/>
                <TextBlock Text="　※ 今日から何日前までの納期日を表示するか" VerticalAlignment="Center" Foreground="#888" Margin="8,0,0,0"/>
            </StackPanel>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="納期日の表示範囲：&#x0a;（未来側）" VerticalAlignment="Center" Margin="0,0,0,12"/>
            <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12">
                <TextBox Name="TxtRangeDays" Width="60" VerticalContentAlignment="Center" Padding="4"/>
                <TextBlock Text="　※ 今日から何日先までの納期日を表示するか" VerticalAlignment="Center" Foreground="#888" Margin="8,0,0,0"/>
            </StackPanel>

            <TextBlock Grid.Row="7" Grid.Column="0" Text="完了日までの営業日数：" VerticalAlignment="Center"/>
            <StackPanel Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal">
                <TextBox Name="TxtCompletionLeadDays" Width="60" VerticalContentAlignment="Center" Padding="4"/>
                <TextBlock Text="　※ 出荷日の何営業日前を完了日とするか" VerticalAlignment="Center" Foreground="#888" Margin="8,0,0,0"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
