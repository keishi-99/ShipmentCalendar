<Window x:Class="ShipmentCalendar.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定" Height="460" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top" FontSize="16" FontWeight="Bold"
                   Text="データソース設定" Margin="0,0,0,16"/>

        <Grid DockPanel.Dock="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 生産計画CSV -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="生産計画CSV：" VerticalAlignment="Center" Margin="0,0,0,12"/>
            <TextBox Grid.Row="0" Grid.Column="1" Name="TxtSeisanKeikaku"
                     VerticalContentAlignment="Center" Padding="4" Margin="0,0,4,12"/>
            <Button Grid.Row="0" Grid.Column="2" Content="参照..." Padding="8,4" Margin="0,0,0,12"
                    Click="BtnBrowseSeisanKeikaku_Click"/>

            <!-- 受入実績CSV -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="受入実績CSV：" VerticalAlignment="Center" Margin="0,0,0,12"/>
            <TextBox Grid.Row="1" Grid.Column="1" Name="TxtUkeireJisseki"
                     VerticalContentAlignment="Center" Padding="4" Margin="0,0,4,12"/>
            <Button Grid.Row="1" Grid.Column="2" Content="参照..." Padding="8,4" Margin="0,0,0,12"
                    Click="BtnBrowseUkeireJisseki_Click"/>

            <!-- 指示工程CSV -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="指示工程CSV：" VerticalAlignment="Center" Margin="0,0,0,12"/>
            <TextBox Grid.Row="2" Grid.Column="1" Name="TxtShijiKotei"
                     VerticalContentAlignment="Center" Padding="4" Margin="0,0,4,12"/>
            <Button Grid.Row="2" Grid.Column="2" Content="参照..." Padding="8,4" Margin="0,0,0,12"
                    Click="BtnBrowseShijiKotei_Click"/>

            <!-- 名称情報CSV -->
            <TextBlock Grid.Row="3" Grid.Column="0" Text="名称情報CSV：" VerticalAlignment="Center" Margin="0,0,0,12"/>
            <TextBox Grid.Row="3" Grid.Column="1" Name="TxtMeishoJoho"
                     VerticalContentAlignment="Center" Padding="4" Margin="0,0,4,12"/>
            <Button Grid.Row="3" Grid.Column="2" Content="参照..." Padding="8,4" Margin="0,0,0,12"
                    Click="BtnBrowseMeishoJoho_Click"/>

            <!-- 自動更新間隔 -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="自動更新間隔（分）：" VerticalAlignment="Center" Margin="0,0,0,12"/>
            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12">
                <TextBox Name="TxtRefreshMinutes" Width="60" VerticalContentAlignment="Center" Padding="4"/>
                <TextBlock Text="　※ 0 で自動更新なし" VerticalAlignment="Center" Foreground="#888" Margin="8,0,0,0"/>
            </StackPanel>

            <!-- 納期範囲（過去） -->
            <TextBlock Grid.Row="5" Grid.Column="0" Text="過去の表示範囲（日）：" VerticalAlignment="Center" Margin="0,0,0,12"/>
            <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12">
                <TextBox Name="TxtPastDays" Width="60" VerticalContentAlignment="Center" Padding="4"/>
                <TextBlock Text="　※ 今日から何日前まで表示するか" VerticalAlignment="Center" Foreground="#888" Margin="8,0,0,0"/>
            </StackPanel>

            <!-- 納期範囲（未来） -->
            <TextBlock Grid.Row="6" Grid.Column="0" Text="未来の表示範囲（日）：" VerticalAlignment="Center"/>
            <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal">
                <TextBox Name="TxtRangeDays" Width="60" VerticalContentAlignment="Center" Padding="4"/>
                <TextBlock Text="　※ 今日から何日先まで表示するか" VerticalAlignment="Center" Foreground="#888" Margin="8,0,0,0"/>
            </StackPanel>
        </Grid>

        <!-- ボタン -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="保存して閉じる" Padding="16,6" Background="#1976D2" Foreground="White"
                    BorderThickness="0" Click="BtnSave_Click" Margin="0,0,8,0"/>
            <Button Content="キャンセル" Padding="16,6" Click="BtnCancel_Click"/>
        </StackPanel>
    </DockPanel>
</Window>
