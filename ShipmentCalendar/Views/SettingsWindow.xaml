<Window
    x:Class="ShipmentCalendar.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="設定"
    Width="520"
    Height="490"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <StackPanel
            Margin="0,16,0,0"
            HorizontalAlignment="Right"
            DockPanel.Dock="Bottom"
            Orientation="Horizontal">
            <Button
                Margin="0,0,8,0"
                Padding="16,6"
                Background="#1976D2"
                BorderThickness="0"
                Click="BtnSave_Click"
                Content="保存して閉じる"
                Foreground="White" />
            <Button
                Padding="16,6"
                Click="BtnCancel_Click"
                Content="キャンセル" />
        </StackPanel>
        <TextBlock
            Name="TxtConnectionStatus"
            Margin="0,8,0,0"
            DockPanel.Dock="Bottom"
            FontSize="12"
            Foreground="#1976D2" />

        <TextBlock
            Margin="0,0,0,16"
            DockPanel.Dock="Top"
            FontSize="16"
            FontWeight="Bold"
            Text="基本設定" />

        <Grid DockPanel.Dock="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--  ODBC DSN  -->
            <TextBlock
                Grid.Row="0"
                Grid.Column="0"
                Margin="0,0,0,12"
                VerticalAlignment="Center"
                Text="ODBC DSN名：" />
            <TextBox
                Name="TxtOdbcDsn"
                Grid.Row="0"
                Grid.Column="1"
                Margin="0,0,4,12"
                Padding="4"
                VerticalContentAlignment="Center"
                ToolTip="例: DrSum_WORKDB_YD" />
            <Button
                Grid.Row="0"
                Grid.Column="2"
                Margin="0,0,0,12"
                Padding="8,4"
                Click="BtnTestConnection_Click"
                Content="接続テスト" />

            <Separator
                Grid.Row="1"
                Grid.ColumnSpan="3"
                Margin="0,4" />

            <TextBlock
                Grid.Row="2"
                Grid.Column="0"
                Margin="0,0,0,12"
                VerticalAlignment="Center"
                Text="自動更新間隔（分）：" />
            <StackPanel
                Grid.Row="2"
                Grid.Column="1"
                Margin="0,0,0,12"
                Orientation="Horizontal">
                <TextBox
                    Name="TxtRefreshMinutes"
                    Width="60"
                    Padding="4"
                    VerticalContentAlignment="Center" />
                <TextBlock
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="#888"
                    Text="　※ 0 で自動更新なし" />
            </StackPanel>

            <TextBlock
                Grid.Row="3"
                Grid.Column="0"
                Margin="0,0,0,12"
                VerticalAlignment="Center"
                Text="納期日の表示範囲：&#x0a;（過去側）" />
            <StackPanel
                Grid.Row="3"
                Grid.Column="1"
                Margin="0,0,0,12"
                Orientation="Horizontal">
                <TextBox
                    Name="TxtPastDays"
                    Width="60"
                    Padding="4"
                    VerticalContentAlignment="Center" />
                <TextBlock
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="#888"
                    Text="　※ 今日から何日前までの納期日を表示するか" />
            </StackPanel>

            <TextBlock
                Grid.Row="4"
                Grid.Column="0"
                Margin="0,0,0,12"
                VerticalAlignment="Center"
                Text="納期日の表示範囲：&#x0a;（未来側）" />
            <StackPanel
                Grid.Row="4"
                Grid.Column="1"
                Margin="0,0,0,12"
                Orientation="Horizontal">
                <TextBox
                    Name="TxtRangeDays"
                    Width="60"
                    Padding="4"
                    VerticalContentAlignment="Center" />
                <TextBlock
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="#888"
                    Text="　※ 今日から何日先までの納期日を表示するか" />
            </StackPanel>

            <TextBlock
                Grid.Row="5"
                Grid.Column="0"
                Margin="0,0,0,12"
                VerticalAlignment="Center"
                Text="完了日までの営業日数：&#x0a;（既定値）" />
            <StackPanel
                Grid.Row="5"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Margin="0,0,0,12"
                Orientation="Horizontal">
                <TextBox
                    Name="TxtCompletionLeadDays"
                    Width="60"
                    Padding="4"
                    VerticalContentAlignment="Center" />
                <TextBlock
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="#888"
                    Text="　※ 出荷日の何営業日前を完了日とするか&#x0a;　　　品番ごとの個別設定が無い場合に使用" />
            </StackPanel>

            <TextBlock
                Grid.Row="6"
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="1日の稼働時間（分）：" />
            <StackPanel
                Grid.Row="6"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Orientation="Horizontal">
                <TextBox
                    Name="TxtDayMinutes"
                    Width="60"
                    Padding="4"
                    VerticalContentAlignment="Center" />
                <TextBlock
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="#888"
                    Text="　※ 工程期限日・工程バーの1営業日分の計算に使う" />
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
