<Window
    x:Class="ShipmentCalendar.Views.OrderDetailWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:ShipmentCalendar.Views"
    Title="注文詳細"
    Width="980"
    Height="700"
    WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <views:StatusToColorConverter x:Key="StatusToColor" />
        <views:ProcessStatusToLabelConverter x:Key="StatusToLabel" />
        <Style x:Key="HeaderLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666666" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
        <Style x:Key="ValueLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="16">
        <!--  閉じるボタン  -->
        <Button
            HorizontalAlignment="Right"
            Padding="20,6"
            Click="BtnClose_Click"
            Content="閉じる"
            DockPanel.Dock="Bottom" />

        <!--  注文基本情報  -->
        <Border
            Margin="0,0,0,12"
            Padding="12"
            Background="#F5F5F5"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="4"
            DockPanel.Dock="Top">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    Style="{StaticResource HeaderLabel}"
                    Text="品目名" />
                <TextBlock
                    Name="TxtProductName"
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Style="{StaticResource ValueLabel}" />

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="2"
                    Style="{StaticResource HeaderLabel}"
                    Text="受注番号" />
                <TextBlock
                    Name="TxtOrderNumber"
                    Grid.Row="1"
                    Grid.Column="2"
                    Style="{StaticResource ValueLabel}" />

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="3"
                    Style="{StaticResource HeaderLabel}"
                    Text="計画数" />
                <TextBlock
                    Name="TxtPlannedQuantity"
                    Grid.Row="1"
                    Grid.Column="3"
                    Style="{StaticResource ValueLabel}" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    Style="{StaticResource HeaderLabel}"
                    Text="品目番号" />
                <TextBlock
                    Name="TxtItemNumber"
                    Grid.Row="3"
                    Grid.Column="0"
                    Style="{StaticResource ValueLabel}" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="1"
                    Style="{StaticResource HeaderLabel}"
                    Text="機種コード" />
                <TextBlock
                    Name="TxtModelCode"
                    Grid.Row="3"
                    Grid.Column="1"
                    Style="{StaticResource ValueLabel}" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="2"
                    Style="{StaticResource HeaderLabel}"
                    Text="製番" />
                <TextBlock
                    Name="TxtManufactureNumber"
                    Grid.Row="3"
                    Grid.Column="2"
                    Style="{StaticResource ValueLabel}" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="3"
                    Style="{StaticResource HeaderLabel}"
                    Text="出荷日 / 完了日" />
                <TextBlock
                    Name="TxtDates"
                    Grid.Row="3"
                    Grid.Column="3"
                    Style="{StaticResource ValueLabel}" />
            </Grid>
        </Border>

        <!--  工程一覧  -->
        <TextBlock
            Margin="0,0,0,6"
            DockPanel.Dock="Top"
            FontSize="13"
            FontWeight="SemiBold"
            Text="工程一覧" />

        <DataGrid
            Name="ProcessGrid"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserSortColumns="False"
            GridLinesVisibility="Horizontal"
            HeadersVisibility="Column"
            IsReadOnly="True"
            SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="40"
                    Binding="{Binding SortOrder}"
                    Header="#" />
                <DataGridTextColumn
                    Width="120"
                    Binding="{Binding ProcessName}"
                    Header="工程名" />
                <DataGridTextColumn
                    Width="120"
                    Binding="{Binding DestinationCode}"
                    Header="指示先番号" />
                <DataGridTextColumn
                    Width="90"
                    Binding="{Binding StartDate, StringFormat=yyyy/MM/dd}"
                    Header="着手予定日" />
                <DataGridTextColumn
                    Width="90"
                    Binding="{Binding DueDate, StringFormat=yyyy/MM/dd}"
                    Header="完了必須日" />
                <DataGridTextColumn
                    Width="90"
                    Binding="{Binding ActualDate, StringFormat=yyyy/MM/dd}"
                    Header="実完了日" />
                <DataGridTemplateColumn Width="70" Header="ステータス">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border
                                Margin="2"
                                Padding="4,2"
                                Background="{Binding Status, Converter={StaticResource StatusToColor}}"
                                CornerRadius="3">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="11"
                                    Text="{Binding Status, Converter={StaticResource StatusToLabel}}" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn
                    Width="80"
                    Binding="{Binding RequiredHoursText}"
                    Header="必要時間" />
                <DataGridTextColumn
                    Width="80"
                    Binding="{Binding OutsourceLeadDaysText}"
                    Header="外注待ち" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
