<Window
    x:Class="ShipmentCalendar.Views.OrderDetailWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:ShipmentCalendar.Converters"
    xmlns:views="clr-namespace:ShipmentCalendar.Views"
    Title="注文詳細"
    Width="1300"
    Height="700"
    WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <views:StatusToColorConverter x:Key="StatusToColor" />
        <converters:ProcessStatusToLabelConverter x:Key="StatusToLabel" />
        <Style x:Key="HeaderLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666666" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
        <Style x:Key="ValueLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="16">
        <!--  閉じるボタン  -->
        <Button
            HorizontalAlignment="Right"
            Padding="20,6"
            Click="BtnClose_Click"
            Content="閉じる"
            DockPanel.Dock="Bottom" />

        <!--  注文基本情報  -->
        <Border
            Margin="0,0,0,12"
            Padding="12"
            Background="#F5F5F5"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="4"
            DockPanel.Dock="Top">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    Style="{StaticResource HeaderLabel}"
                    Text="品目名" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Style="{StaticResource ValueLabel}"
                    Text="{Binding ProductName}" />

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="2"
                    Style="{StaticResource HeaderLabel}"
                    Text="受注番号" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="2"
                    Style="{StaticResource ValueLabel}"
                    Text="{Binding OrderNumber}" />

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="3"
                    Style="{StaticResource HeaderLabel}"
                    Text="計画数" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="3"
                    Style="{StaticResource ValueLabel}"
                    Text="{Binding PlannedQuantity}" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    Style="{StaticResource HeaderLabel}"
                    Text="品目番号" />
                <TextBlock
                    Grid.Row="3"
                    Grid.Column="0"
                    Style="{StaticResource ValueLabel}"
                    Text="{Binding ItemNumber}" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="1"
                    Style="{StaticResource HeaderLabel}"
                    Text="機種コード" />
                <TextBlock
                    Grid.Row="3"
                    Grid.Column="1"
                    Style="{StaticResource ValueLabel}"
                    Text="{Binding ModelCode}" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="2"
                    Style="{StaticResource HeaderLabel}"
                    Text="製番" />
                <TextBlock
                    Grid.Row="3"
                    Grid.Column="2"
                    Style="{StaticResource ValueLabel}"
                    Text="{Binding ManufactureNumber}" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="3"
                    Style="{StaticResource HeaderLabel}"
                    Text="出荷日 / 完了期限日" />
                <TextBlock Grid.Row="3" Grid.Column="3" Style="{StaticResource ValueLabel}">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0:yyyy/MM/dd} / {1:yyyy/MM/dd}">
                            <Binding Path="DeliveryDate" />
                            <Binding Path="CompletionDate" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </Grid>
        </Border>

        <!--  工程バー  -->
        <DockPanel Margin="0,0,0,4" DockPanel.Dock="Top" LastChildFill="False">
            <TextBlock
                DockPanel.Dock="Left"
                VerticalAlignment="Center"
                FontSize="13"
                FontWeight="SemiBold"
                Text="工程バー" />
            <ToggleButton
                Name="ToggleLaneView"
                DockPanel.Dock="Right"
                Padding="8,2"
                Checked="ToggleLaneView_Checked"
                Content="工程別レーン表示"
                Unchecked="ToggleLaneView_Unchecked" />
        </DockPanel>
        <views:ProcessBarControl
            x:Name="DetailProcessBar"
            Height="48"
            Margin="0,0,0,12"
            DockPanel.Dock="Top" />

        <!--  工程別レーン表示: 工程ごとに標準を背景バー、実績を重ねたバーとして表示する（製品別実績分析と同じデザイン）  -->
        <ItemsControl
            Name="LaneList"
            Margin="0,0,0,12"
            DockPanel.Dock="Top"
            Visibility="Collapsed">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            FontSize="11"
                            Text="{Binding ProcessName}"
                            TextTrimming="CharacterEllipsis"
                            ToolTip="{Binding ProcessName}" />
                        <!--  標準を固定長の背景バーとして表現し、実績をその上に重ねる（標準以内は通常色、超過分は警告色）。
                              ラベルはバーと同じセルに重ね、固定オフセットで配置することで、実績が標準を超えて
                              バーが伸びてもラベルの位置がズレないようにする  -->
                        <Grid Grid.Column="1">
                            <Border
                                Width="200"
                                Height="16"
                                HorizontalAlignment="Left"
                                Background="#DCE3EC"
                                ToolTip="{Binding StandardMinutes, StringFormat='標準 {0:F1}分'}" />
                            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                <Border
                                    Width="{Binding ActualWithinStandardSize}"
                                    Height="16"
                                    Background="#6699CC"
                                    ToolTip="{Binding ActualTooltip}" />
                                <Border
                                    Width="{Binding ActualOverflowSize}"
                                    Height="16"
                                    Background="#B3D9534F"
                                    ToolTip="{Binding ActualTooltip}" />
                            </StackPanel>
                            <StackPanel
                                Margin="210,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <TextBlock
                                    FontSize="10"
                                    FontWeight="SemiBold"
                                    Foreground="{Binding ActualTextBrush}"
                                    Text="{Binding ActualMinutesText}" />
                                <TextBlock
                                    FontSize="10"
                                    Foreground="#666666"
                                    Text="{Binding StandardComparisonText}" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!--  工程一覧  -->
        <TextBlock
            Margin="0,0,0,6"
            DockPanel.Dock="Top"
            FontSize="13"
            FontWeight="SemiBold"
            Text="工程一覧" />

        <DataGrid
            Name="ProcessGrid"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserSortColumns="False"
            GridLinesVisibility="Horizontal"
            HeadersVisibility="Column"
            IsReadOnly="True"
            SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="40"
                    Binding="{Binding SortOrder}"
                    Header="#" />
                <DataGridTextColumn
                    Width="250"
                    Binding="{Binding ProcessName}"
                    Header="工程名" />
                <DataGridTextColumn
                    Width="90"
                    Binding="{Binding DepartmentName}"
                    Header="担当部署" />
                <DataGridTextColumn
                    Width="70"
                    Binding="{Binding DestinationCode}"
                    Header="指示先番号" />
                <DataGridTextColumn
                    Width="90"
                    Binding="{Binding StartDate, StringFormat=yyyy/MM/dd}"
                    Header="着手期限日" />
                <DataGridTextColumn
                    Width="90"
                    Binding="{Binding DueDate, StringFormat=yyyy/MM/dd}"
                    Header="完了期限日" />
                <DataGridTextColumn
                    Width="90"
                    Binding="{Binding ActualDate, StringFormat=yyyy/MM/dd}"
                    Header="受入日" />
                <DataGridTextColumn
                    Width="90"
                    Binding="{Binding WorkerName}"
                    Header="担当者" />
                <DataGridTextColumn
                    Width="80"
                    Binding="{Binding RequiredHoursText}"
                    Header="必要時間" />
                <DataGridTextColumn
                    Width="80"
                    Binding="{Binding ActualWorkHoursText}"
                    Header="実績工数" />
                <DataGridTemplateColumn Width="70" Header="ステータス">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border
                                Margin="2"
                                Padding="4,2"
                                Background="{Binding Status, Converter={StaticResource StatusToColor}}"
                                CornerRadius="3">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="11"
                                    Text="{Binding Status, Converter={StaticResource StatusToLabel}}" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn
                    Width="60"
                    Binding="{Binding OutsourceLeadDaysText}"
                    Header="外注待ち" />
                <DataGridTextColumn
                    Width="70"
                    Binding="{Binding DwellTimeText}"
                    Header="滞留時間" />
                <DataGridTextColumn
                    Width="70"
                    Binding="{Binding WarningDaysText}"
                    Header="警告日数" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
