<Window
    x:Class="ShipmentCalendar.Views.UnregisteredItemPickerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="未登録品目を選択"
    Width="460"
    Height="560"
    WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <!--  検索ボックス  -->
        <TextBox
            Name="TxtSearch"
            Margin="0,0,0,8"
            Padding="6,4"
            DockPanel.Dock="Top"
            TextChanged="TxtSearch_TextChanged"
            VerticalContentAlignment="Center" />

        <!--  全選択・全解除ボタン  -->
        <StackPanel
            Margin="0,0,0,8"
            DockPanel.Dock="Top"
            Orientation="Horizontal">
            <Button
                Margin="0,0,8,0"
                Padding="8,4"
                Click="BtnSelectAll_Click"
                Content="全選択" />
            <Button
                Padding="8,4"
                Click="BtnDeselectAll_Click"
                Content="全解除" />
        </StackPanel>

        <!--  ボタン  -->
        <StackPanel
            Margin="0,8,0,0"
            HorizontalAlignment="Right"
            DockPanel.Dock="Bottom"
            Orientation="Horizontal">
            <Button
                Margin="0,0,8,0"
                Padding="16,6"
                Background="#1976D2"
                BorderThickness="0"
                Click="BtnRegister_Click"
                Content="登録"
                Foreground="White"
                IsDefault="True" />
            <Button
                Padding="16,6"
                Click="BtnCancel_Click"
                Content="キャンセル"
                IsCancel="True" />
        </StackPanel>

        <!--  未登録品目一覧（チェックボックス + 品目番号 + 品目名）  -->
        <ListView Name="LstItems">
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="40">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="140" Header="品目番号" DisplayMemberBinding="{Binding ItemNumber}" />
                    <GridViewColumn Width="220" Header="品目名" DisplayMemberBinding="{Binding DisplayName}" />
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</Window>
