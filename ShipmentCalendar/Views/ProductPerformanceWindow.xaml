<Window
    x:Class="ShipmentCalendar.Views.ProductPerformanceWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:ShipmentCalendar.Views"
    Title="製品別実績分析"
    Width="1100"
    Height="750"
    WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <!--  タイムライン表示: 製番ごとに標準/実績バーのペアを並べる  -->
        <DataTemplate x:Key="GanttPairTemplate">
            <Border
                Margin="0,0,0,12"
                Padding="8"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                CornerRadius="4">
                <StackPanel>
                    <TextBlock Margin="0,0,0,6" FontWeight="SemiBold">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="製番: {0}　計画数: {1}　最新受入日: {2:yyyy/MM/dd}">
                                <Binding Path="Seiban" />
                                <Binding Path="PlannedQuantity" />
                                <Binding Path="LatestActualDate" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <!--  標準工数バー（1行目）/ 実績工数バー（2行目）。日数ルーラーは一覧上部の共通ヘッダーで1回だけ表示する  -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel
                            Grid.Row="0"
                            Grid.Column="0"
                            VerticalAlignment="Center">
                            <TextBlock
                                FontSize="11"
                                Foreground="#666666"
                                Text="標準" />
                            <TextBlock
                                FontSize="10"
                                Foreground="#999999"
                                Text="{Binding StandardTotalText}" />
                        </StackPanel>
                        <views:ProcessBarControl
                            Grid.Row="0"
                            Grid.Column="1"
                            Height="32"
                            Processes="{Binding StandardProcesses}"
                            ShowDateBar="False"
                            SuppressHeaderRow="True"
                            TotalMinutesOverride="{Binding ScaleMinutes}" />
                        <StackPanel
                            Grid.Row="1"
                            Grid.Column="0"
                            VerticalAlignment="Center">
                            <TextBlock
                                FontSize="11"
                                Foreground="#666666"
                                Text="実績" />
                            <TextBlock
                                FontSize="10"
                                Foreground="#999999"
                                Text="{Binding ActualTotalText}" />
                        </StackPanel>
                        <views:ProcessBarControl
                            Grid.Row="1"
                            Grid.Column="1"
                            Height="32"
                            Processes="{Binding ActualProcesses}"
                            ShowDateBar="False"
                            SuppressHeaderRow="True"
                            TotalMinutesOverride="{Binding ScaleMinutes}" />
                    </Grid>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!--  工程別レーン表示: 工程ごとに固定レーンを設け、標準/実績を棒グラフとして並べる  -->
        <DataTemplate x:Key="LaneTemplate">
            <Border
                Margin="0,0,0,12"
                Padding="8"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                CornerRadius="4">
                <StackPanel>
                    <TextBlock Margin="0,0,0,6" FontWeight="SemiBold">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="製番: {0}　計画数: {1}　最新受入日: {2:yyyy/MM/dd}">
                                <Binding Path="Seiban" />
                                <Binding Path="PlannedQuantity" />
                                <Binding Path="LatestActualDate" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding Lanes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        Text="{Binding ProcessName}"
                                        TextTrimming="CharacterEllipsis"
                                        ToolTip="{Binding ProcessName}" />
                                    <!--  標準を固定長の背景バーとして表現し、実績をその上に重ねる（標準以内は通常色、超過分は警告色）。
                                          ラベルはバーと同じセルに重ね、固定オフセットで配置することで、実績が標準を超えて
                                          バーが伸びてもラベルの位置がズレないようにする  -->
                                    <Grid Grid.Column="1">
                                        <Border
                                            Width="200"
                                            Height="16"
                                            HorizontalAlignment="Left"
                                            Background="#DCE3EC"
                                            ToolTip="{Binding StandardMinutes, StringFormat='標準 {0:F1}分'}" />
                                        <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                            <Border
                                                Width="{Binding ActualWithinStandardSize}"
                                                Height="16"
                                                Background="#6699CC"
                                                ToolTip="{Binding ActualTooltip}" />
                                            <Border
                                                Width="{Binding ActualOverflowSize}"
                                                Height="16"
                                                Background="#D9534F"
                                                ToolTip="{Binding ActualTooltip}" />
                                        </StackPanel>
                                        <StackPanel
                                            Margin="210,0,0,0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <TextBlock
                                                FontSize="10"
                                                FontWeight="SemiBold"
                                                Foreground="{Binding ActualTextBrush}"
                                                Text="{Binding ActualMinutesText}" />
                                            <TextBlock
                                                FontSize="10"
                                                Foreground="#666666"
                                                Text="{Binding StandardComparisonText}" />
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <DockPanel Margin="16">
        <!--  閉じるボタン  -->
        <Button
            HorizontalAlignment="Right"
            Padding="20,6"
            Click="BtnClose_Click"
            Content="閉じる"
            DockPanel.Dock="Bottom" />

        <!--  検索条件  -->
        <Border
            Margin="0,0,0,12"
            Padding="12"
            Background="#F5F5F5"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="4"
            DockPanel.Dock="Top">
            <StackPanel Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Text="品目番号:" />
                <TextBox
                    Name="TxtSelectedItem"
                    Width="180"
                    Margin="0,0,4,0"
                    VerticalContentAlignment="Center"
                    IsReadOnly="True" />
                <Button
                    Margin="0,0,16,0"
                    Padding="8,4"
                    Click="BtnSelectItem_Click"
                    Content="選択" />

                <TextBlock
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Text="開始日:" />
                <DatePicker Name="StartDatePicker" Margin="0,0,16,0" />

                <TextBlock
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Text="終了日:" />
                <DatePicker Name="EndDatePicker" Margin="0,0,16,0" />

                <TextBlock
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Text="表示件数:" />
                <ComboBox
                    Name="CountCombo"
                    Width="80"
                    Margin="0,0,16,0"
                    SelectedIndex="2">
                    <ComboBoxItem Content="10" Tag="10" />
                    <ComboBoxItem Content="50" Tag="50" />
                    <ComboBoxItem Content="100" Tag="100" />
                    <ComboBoxItem Content="すべて" Tag="" />
                </ComboBox>

                <Button
                    Name="BtnSearch"
                    Margin="0,0,16,0"
                    Padding="16,4"
                    Click="BtnSearch_Click"
                    Content="検索" />

                <ToggleButton
                    Name="ToggleLaneView"
                    Padding="8,4"
                    VerticalAlignment="Center"
                    Checked="ToggleLaneView_Checked"
                    Content="工程別レーン表示"
                    Unchecked="ToggleLaneView_Unchecked" />
            </StackPanel>
        </Border>

        <TextBlock
            Name="TxtStatus"
            Margin="0,0,0,8"
            DockPanel.Dock="Top"
            Foreground="#666666" />

        <!--  タイムライン表示専用の共通日数ルーラー。全注文が同じScaleMinutesを共有しているため、1回だけ表示すれば足りる  -->
        <Border
            Name="RulerHeaderBorder"
            Margin="0,0,0,8"
            Padding="8"
            DockPanel.Dock="Top"
            Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="56" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Name="DayRulerGrid" Grid.Column="1" Height="16" />
            </Grid>
        </Border>

        <!--  製番ごとの結果一覧（タイムライン表示 / 工程別レーン表示をトグルで切替）  -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl Name="ResultsControl" ItemTemplate="{StaticResource GanttPairTemplate}" />
        </ScrollViewer>
    </DockPanel>
</Window>
