<Window
    x:Class="ShipmentCalendar.Views.ProductPerformanceWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:ShipmentCalendar.Views"
    Title="製品別実績分析"
    Width="1100"
    Height="750"
    WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <!--  タイムライン表示: 製番ごとに標準/実績バーのペアを並べる  -->
        <DataTemplate x:Key="GanttPairTemplate">
            <Border
                Margin="0,0,0,12"
                Padding="8"
                Background="Transparent"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                Cursor="Hand"
                CornerRadius="4"
                MouseLeftButtonDown="OrderCard_MouseLeftButtonDown"
                ToolTip="ダブルクリックで注文詳細を表示">
                <StackPanel>
                    <StackPanel Margin="0,0,0,6" Orientation="Horizontal">
                        <TextBlock FontWeight="SemiBold">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="製番: {0}　計画数: {1}　最新受入日: {2:yyyy/MM/dd}">
                                    <Binding Path="Seiban" />
                                    <Binding Path="PlannedQuantity" />
                                    <Binding Path="LatestActualDate" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <!--  順序999（最終受入）の実績がまだ無い場合は作業途中として明示する  -->
                        <Border
                            Margin="8,0,0,0"
                            Padding="6,1"
                            VerticalAlignment="Center"
                            Background="#F0AD4E"
                            CornerRadius="3"
                            Visibility="{Binding IsInProgress, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock
                                FontSize="10"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="未完了" />
                        </Border>
                    </StackPanel>
                    <!--  標準工数バー（1行目）/ 実績工数バー（2行目）。日数ルーラーは一覧上部の共通ヘッダーで1回だけ表示する  -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel
                            Grid.Row="0"
                            Grid.Column="0"
                            VerticalAlignment="Center">
                            <TextBlock
                                FontSize="11"
                                Foreground="#666666"
                                Text="標準" />
                            <TextBlock
                                FontSize="10"
                                Foreground="#999999"
                                Text="{Binding StandardTotalText}" />
                        </StackPanel>
                        <views:ProcessBarControl
                            Grid.Row="0"
                            Grid.Column="1"
                            Height="32"
                            Processes="{Binding StandardProcesses}"
                            ShowDateBar="False"
                            SuppressHeaderRow="True"
                            TotalMinutesOverride="{Binding ScaleMinutes}" />
                        <StackPanel
                            Grid.Row="1"
                            Grid.Column="0"
                            VerticalAlignment="Center">
                            <TextBlock
                                FontSize="11"
                                Foreground="#666666"
                                Text="実績" />
                            <TextBlock
                                FontSize="10"
                                Foreground="#999999"
                                Text="{Binding ActualTotalText}" />
                        </StackPanel>
                        <views:ProcessBarControl
                            Grid.Row="1"
                            Grid.Column="1"
                            Height="32"
                            Processes="{Binding ActualProcesses}"
                            ShowDateBar="False"
                            SuppressHeaderRow="True"
                            TotalMinutesOverride="{Binding ScaleMinutes}" />
                    </Grid>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!--  工程別レーン表示: 工程ごとに固定レーンを設け、標準/実績を棒グラフとして並べる  -->
        <DataTemplate x:Key="LaneTemplate">
            <Border
                Margin="0,0,0,12"
                Padding="8"
                Background="Transparent"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                Cursor="Hand"
                CornerRadius="4"
                MouseLeftButtonDown="OrderCard_MouseLeftButtonDown"
                ToolTip="ダブルクリックで注文詳細を表示">
                <StackPanel>
                    <TextBlock Margin="0,0,0,6" FontWeight="SemiBold">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="製番: {0}　計画数: {1}　最新受入日: {2:yyyy/MM/dd}">
                                <Binding Path="Seiban" />
                                <Binding Path="PlannedQuantity" />
                                <Binding Path="LatestActualDate" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding LanesWithTotal}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!--  合計レーンは通常の工程レーンと区別するため、上に区切り線を入れて余白を広げる  -->
                                <Border Margin="0,0,0,6">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTotal}" Value="True">
                                                    <Setter Property="BorderBrush" Value="#CCCCCC" />
                                                    <Setter Property="BorderThickness" Value="0,1,0,0" />
                                                    <Setter Property="Padding" Value="0,6,0,0" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        Text="{Binding ProcessName}"
                                        TextTrimming="CharacterEllipsis"
                                        ToolTip="{Binding ProcessName}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTotal}" Value="True">
                                                        <Setter Property="FontWeight" Value="Bold" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <!--  標準を固定長の背景バーとして表現し、実績をその上に重ねる（標準以内は通常色、超過分は警告色）。
                                          ラベルはバーと同じセルに重ね、固定オフセットで配置することで、実績が標準を超えて
                                          バーが伸びてもラベルの位置がズレないようにする  -->
                                    <Grid Grid.Column="1">
                                        <Border
                                            Width="200"
                                            Height="16"
                                            HorizontalAlignment="Left"
                                            Background="#DCE3EC"
                                            BorderBrush="#9AB0CC"
                                            BorderThickness="1"
                                            ToolTip="{Binding StandardMinutes, StringFormat='標準 {0:F1}分'}" />
                                        <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                            <Border
                                                Width="{Binding ActualWithinStandardSize}"
                                                Height="16"
                                                Background="#6699CC"
                                                ToolTip="{Binding ActualTooltip}" />
                                            <Border
                                                Width="{Binding ActualOverflowSize}"
                                                Height="16"
                                                Background="#B3D9534F"
                                                ToolTip="{Binding ActualTooltip}" />
                                        </StackPanel>
                                        <StackPanel
                                            Margin="210,0,0,0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <TextBlock
                                                Width="48"
                                                FontSize="10"
                                                FontWeight="SemiBold"
                                                Foreground="{Binding ActualTextBrush}"
                                                Text="{Binding ActualMinutesText}"
                                                TextAlignment="Right" />
                                            <TextBlock
                                                FontSize="10"
                                                Foreground="#666666"
                                                Text=" / " />
                                            <TextBlock
                                                Width="48"
                                                FontSize="10"
                                                Foreground="#666666"
                                                Text="{Binding StandardMinutesText}"
                                                TextAlignment="Right" />
                                            <TextBlock
                                                Width="60"
                                                Margin="4,0,0,0"
                                                FontSize="10"
                                                Foreground="{Binding ActualTextBrush}"
                                                Text="{Binding DifferenceText}"
                                                TextAlignment="Right" />
                                            <TextBlock
                                                FontSize="10"
                                                Foreground="{Binding ActualTextBrush}"
                                                Text="{Binding PercentageSeparatorText}" />
                                            <TextBlock
                                                Width="40"
                                                FontSize="10"
                                                Foreground="{Binding ActualTextBrush}"
                                                Text="{Binding PercentageText}"
                                                TextAlignment="Right" />
                                            <TextBlock
                                                FontSize="10"
                                                Foreground="{Binding ActualTextBrush}"
                                                Text=")" />
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <DockPanel Margin="16">
        <!--  閉じるボタン  -->
        <Button
            HorizontalAlignment="Right"
            Padding="20,6"
            Click="BtnClose_Click"
            Content="閉じる"
            DockPanel.Dock="Bottom" />

        <!--  検索条件  -->
        <Border
            Margin="0,0,0,12"
            Padding="12"
            Background="#F5F5F5"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="4"
            DockPanel.Dock="Top">
            <StackPanel Orientation="Horizontal">
                <!--  1列目: 上段=品目番号、下段=品目名  -->
                <StackPanel Margin="0,0,16,0">
                    <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                        <TextBlock
                            Width="64"
                            VerticalAlignment="Center"
                            Text="品目番号:" />
                        <!--  品目名ボックス（幅220）と右端を揃えるため、テキストボックスを可変幅にしてボタン分を差し引く  -->
                        <Grid Width="220">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                Name="TxtSelectedItem"
                                Grid.Column="0"
                                Height="24"
                                Margin="0,0,4,0"
                                Background="#F0F0F0"
                                VerticalContentAlignment="Center"
                                IsReadOnly="True" />
                            <Button
                                Grid.Column="1"
                                Height="24"
                                Padding="8,2"
                                Click="BtnSelectItem_Click"
                                Content="選択" />
                        </Grid>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Width="64"
                            VerticalAlignment="Center"
                            Text="品目名:" />
                        <TextBox
                            Name="TxtSelectedItemName"
                            Width="220"
                            Height="24"
                            Background="#F0F0F0"
                            VerticalContentAlignment="Center"
                            IsReadOnly="True" />
                    </StackPanel>
                </StackPanel>

                <!--  2列目: 上段=開始日、下段=終了日  -->
                <StackPanel Margin="0,0,16,0">
                    <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                        <TextBlock
                            Width="50"
                            VerticalAlignment="Center"
                            Text="開始日:" />
                        <DatePicker Name="StartDatePicker" Height="24" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Width="50"
                            VerticalAlignment="Center"
                            Text="終了日:" />
                        <DatePicker Name="EndDatePicker" Height="24" />
                    </StackPanel>
                </StackPanel>

                <!--  検索ボタン: 日付フィルターの右、2段ぶんの高さの中央に配置  -->
                <StackPanel Margin="0,0,16,0" VerticalAlignment="Center">
                    <Button
                        Name="BtnSearch"
                        Height="24"
                        Padding="16,4"
                        Click="BtnSearch_Click"
                        Content="検索" />
                </StackPanel>

                <!--  表示形式  -->
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Margin="0,0,0,2" Text="表示形式:" />
                    <ComboBox
                        Name="ViewModeCombo"
                        Width="140"
                        Height="24"
                        SelectionChanged="ViewModeCombo_SelectionChanged">
                        <ComboBoxItem Content="タイムライン表示" />
                        <ComboBoxItem Content="工程別レーン表示" />
                        <ComboBoxItem Content="工程比較表" />
                    </ComboBox>
                </StackPanel>
            </StackPanel>
        </Border>

        <StackPanel
            Margin="0,0,0,8"
            DockPanel.Dock="Top"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
            <ProgressBar
                Name="SearchProgressBar"
                Width="160"
                Height="10"
                Margin="0,0,8,0"
                VerticalAlignment="Center"
                IsIndeterminate="True"
                Visibility="Collapsed" />
            <TextBlock
                Name="TxtStatus"
                VerticalAlignment="Center"
                Foreground="#666666" />
        </StackPanel>

        <!--  タイムライン表示専用の共通日数ルーラー。全注文が同じScaleMinutesを共有しているため、1回だけ表示すれば足りる  -->
        <Border
            Name="RulerHeaderBorder"
            Margin="0,0,0,8"
            Padding="8"
            DockPanel.Dock="Top"
            Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="56" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Name="DayRulerGrid" Grid.Column="1" Height="16" />
            </Grid>
        </Border>

        <!--  製番ごとの結果一覧（タイムライン表示 / 工程別レーン表示 / 工程比較表をコンボボックスで切替）  -->
        <Grid>
            <ScrollViewer Name="ResultsScrollViewer" VerticalScrollBarVisibility="Auto">
                <ItemsControl Name="ResultsControl" ItemTemplate="{StaticResource GanttPairTemplate}" />
            </ScrollViewer>
            <!--  工程比較表: 列=工程、行=注文。各セルは標準/実績の重ね描きバーを50%スケールで表示する  -->
            <DataGrid
                Name="MatrixGrid"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                IsReadOnly="True"
                MouseDoubleClick="MatrixGrid_MouseDoubleClick"
                RowHeight="28"
                SelectionMode="Single"
                ToolTip="ダブルクリックで注文詳細を表示"
                Visibility="Collapsed" />
        </Grid>
    </DockPanel>
</Window>
