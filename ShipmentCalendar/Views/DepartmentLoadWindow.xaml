<Window x:Class="ShipmentCalendar.Views.DepartmentLoadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="部署別 締切集中度" Height="500" Width="900"
        WindowStartupLocation="CenterOwner"
        PreviewMouseDown="Window_PreviewMouseDown">
    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top" FontSize="16" FontWeight="Bold"
                   Text="部署別 締切集中度" Margin="0,0,0,4"/>
        <TextBlock DockPanel.Dock="Top" Foreground="#666666" TextWrapping="Wrap" Margin="0,0,0,12"
                   Text="表示中の注文の未完了工程について、完了必須日（DueDate）ごとの件数を部署別に集計したものです。実際の着手日ではなく「前倒し着手をしなければこの日に締切を迎える」という目安のため、実際の負荷や稼働率とは異なります。"/>

        <TextBlock DockPanel.Dock="Bottom" Name="TxtEmpty" Margin="0,8,0,0" Foreground="#666666"
                   Text="表示中の注文に未完了工程がありません。" Visibility="Collapsed"/>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="やや集中：合計" VerticalAlignment="Center"/>
            <TextBox Name="TxtCautionMinutes" Width="60" Margin="4,0" Padding="2" VerticalContentAlignment="Center"/>
            <TextBlock Text="分以上　　集中：合計" VerticalAlignment="Center"/>
            <TextBox Name="TxtConcentratedMinutes" Width="60" Margin="4,0" Padding="2" VerticalContentAlignment="Center"/>
            <TextBlock Text="分以上" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <Button Content="適用" Padding="12,4" Click="BtnApplyThreshold_Click"/>
        </StackPanel>

        <DataGrid Name="LoadGrid"
                  AutoGenerateColumns="False" CanUserAddRows="False"
                  IsReadOnly="True" HeadersVisibility="Column"
                  HorizontalScrollBarVisibility="Auto" FrozenColumnCount="1" SelectionUnit="Cell">
            <DataGrid.Columns>
                <DataGridTextColumn Header="部署" Binding="{Binding DepartmentName}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!--  セルダブルクリック時に該当注文一覧を表示するポップアップ  -->
        <Popup Name="CellDetailPopup" StaysOpen="True" AllowsTransparency="True" Placement="Bottom">
            <Border Background="White" BorderBrush="#999999" BorderThickness="1" CornerRadius="4" Padding="8" MaxWidth="320">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Name="TxtPopupTitle" FontWeight="Bold" Margin="0,0,0,4"/>
                    <ListBox Name="CellDetailList" MaxHeight="220" BorderThickness="0"
                             MouseDoubleClick="CellDetailList_MouseDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,2" Cursor="Hand" ToolTip="ダブルクリックで注文詳細を表示">
                                    <TextBlock FontSize="11" FontWeight="SemiBold" Text="{Binding ManufactureNumber}"/>
                                    <TextBlock FontSize="10" Foreground="#666666">
                                        <Run Text="{Binding ProductName, Mode=OneWay}"/>
                                        <Run Text="　"/>
                                        <Run Text="{Binding ProcessName, Mode=OneWay}"/>
                                        <Run Text="　"/>
                                        <Run Text="{Binding RequiredTimeText, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </Popup>
    </DockPanel>
</Window>
