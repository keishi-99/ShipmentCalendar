<Window x:Class="ShipmentCalendar.Views.ProcessSettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ShipmentCalendar.Views"
        Title="工程設定" Height="560" Width="820"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <local:DeptIdToNameConverter x:Key="DeptIdToNameConverter"/>
    </Window.Resources>
    <DockPanel Margin="16">
        <!-- ボタン・ステータスを先に宣言しないと高さ不足で隠れる -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="品目番号ごと削除" Padding="12,6" Background="#D32F2F" Foreground="White"
                    BorderThickness="0" Click="BtnDeleteItem_Click" Margin="0,0,8,0"/>
            <Button Content="保存" Padding="16,6" Background="#1976D2" Foreground="White"
                    BorderThickness="0" Click="BtnSave_Click" Margin="0,0,8,0"/>
            <Button Content="閉じる" Padding="16,6" Click="BtnClose_Click"/>
        </StackPanel>
        <TextBlock Name="TxtStatus" DockPanel.Dock="Bottom" Margin="0,4,0,0" Foreground="#666666"/>

        <TextBlock DockPanel.Dock="Top" FontSize="16" FontWeight="Bold"
                   Text="品目ごとの工程設定" Margin="0,0,0,12"/>

        <!-- 登録済み品目番号の選択 -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="登録済み：" VerticalAlignment="Center" Width="70"/>
            <ComboBox Name="CmbRegistered" Width="220"
                      SelectionChanged="CmbRegistered_SelectionChanged"
                      ToolTip="DB に保存済みの品目番号"/>
        </StackPanel>

        <!-- 品目番号入力 + 取り込みボタン -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
            <TextBlock Text="品目番号：" VerticalAlignment="Center" Width="70"/>
            <TextBox Name="TxtItemNumber" Width="220"
                     VerticalContentAlignment="Center" Padding="4,2"
                     ToolTip="VP_指示工程情報_YD の品目番号と完全一致するコードを入力"/>
            <Button Content="CSVから取り込む" Padding="8,4" Margin="8,0,0,0"
                    Click="BtnImport_Click"/>
        </StackPanel>

        <!-- 品目名（初期値はCSV品目名、変更可） -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="品目名：" VerticalAlignment="Center" Width="70"/>
            <TextBox Name="TxtItemName" Width="320"
                     VerticalContentAlignment="Center" Padding="4,2"
                     ToolTip="アプリ上で表示する品目名（初期値はCSVの品目名）"/>
        </StackPanel>

        <!-- 工程リスト（順序・指示内容は読み取り専用、工程名・LT・設定は編集可） -->
        <DataGrid Name="ProcessGrid" DockPanel.Dock="Top" Height="310"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  HeadersVisibility="Column" Margin="0,0,0,8"
                  SelectionUnit="Cell" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="順序" Binding="{Binding SortOrder}" Width="50"
                                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#888888"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="工程名（変更可）"
                                    Binding="{Binding ProcessName, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*"/>
                <DataGridTextColumn Header="指示内容" Binding="{Binding CsvColumnName}" Width="90"
                                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#888888"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="製造LT（日）"
                                    Binding="{Binding LeadTimeDays, UpdateSourceTrigger=PropertyChanged}"
                                    Width="90"/>
                <DataGridCheckBoxColumn Header="表示"
                                        Binding="{Binding IsVisible, UpdateSourceTrigger=PropertyChanged}"
                                        Width="45"/>
                <DataGridTextColumn Header="警告（日前）"
                                    Binding="{Binding WarningDaysBeforeDeadline, UpdateSourceTrigger=PropertyChanged}"
                                    Width="80"/>
                <!-- 担当部署コンボボックス列 -->
                <DataGridTemplateColumn Header="担当部署" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DepartmentId, Converter={StaticResource DeptIdToNameConverter}}"
                                       VerticalAlignment="Center" Padding="4,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding Tag, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="Name"
                                      SelectedValue="{Binding DepartmentId, UpdateSourceTrigger=PropertyChanged}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="" Width="44">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="✕" Padding="4,2" FontSize="11"
                                    Background="Transparent" BorderThickness="0" Foreground="#D32F2F"
                                    Click="BtnDeleteRow_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>
