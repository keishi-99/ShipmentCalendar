<Window
    x:Class="ShipmentCalendar.Views.ProcessSettingWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:ShipmentCalendar.Views"
    Title="工程設定"
    Width="820"
    Height="560"
    WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <local:DeptIdToNameConverter x:Key="DeptIdToNameConverter" />
    </Window.Resources>
    <Grid>
    <TabControl Margin="16">
    <TabItem Header="半製品">
    <DockPanel Margin="8">
        <!--  ボタン・ステータスを先に宣言しないと高さ不足で隠れる  -->
        <StackPanel
            Margin="0,8,0,0"
            HorizontalAlignment="Right"
            DockPanel.Dock="Bottom"
            Orientation="Horizontal">
            <Button
                Margin="0,0,8,0"
                Padding="12,6"
                Background="#D32F2F"
                BorderThickness="0"
                Click="BtnDeleteItem_Click"
                Content="品目番号ごと削除"
                Foreground="White" />
            <Button
                Margin="0,0,8,0"
                Padding="16,6"
                Background="#1976D2"
                BorderThickness="0"
                Click="BtnSave_Click"
                Content="保存"
                Foreground="White" />
            <Button
                Padding="16,6"
                Click="BtnClose_Click"
                Content="閉じる" />
        </StackPanel>
        <TextBlock
            Name="TxtStatus"
            Margin="0,4,0,0"
            DockPanel.Dock="Bottom"
            Foreground="#666666" />

        <TextBlock
            Margin="0,0,0,12"
            DockPanel.Dock="Top"
            FontSize="16"
            FontWeight="Bold"
            Text="品目ごとの工程設定" />

        <!--  登録済み品目番号の選択  -->
        <StackPanel
            Margin="0,0,0,6"
            DockPanel.Dock="Top"
            Orientation="Horizontal">
            <TextBlock
                Width="70"
                VerticalAlignment="Center"
                Text="登録済み：" />
            <TextBox
                Name="TxtRegisteredDisplay"
                Width="220"
                Padding="4,2"
                IsReadOnly="True"
                VerticalContentAlignment="Center"
                Background="#F5F5F5"
                ToolTip="DB に保存済みの品目番号" />
            <Button
                Margin="8,0,0,0"
                Padding="8,4"
                Click="BtnSelectItem_Click"
                Content="一覧から選択" />
        </StackPanel>

        <!--  品目番号入力 + 取り込みボタン  -->
        <StackPanel
            Margin="0,0,0,4"
            DockPanel.Dock="Top"
            Orientation="Horizontal">
            <TextBlock
                Width="70"
                VerticalAlignment="Center"
                Text="品目番号：" />
            <TextBox
                Name="TxtItemNumber"
                Width="220"
                Padding="4,2"
                VerticalContentAlignment="Center"
                ToolTip="VP_指示工程情報_YD の品目番号と完全一致するコードを入力" />
            <Button
                Margin="8,0,0,0"
                Padding="8,4"
                Click="BtnImport_Click"
                Content="PRONESSから工程取得" />
        </StackPanel>

        <!--  品目名（初期値はCSV品目名、変更可）  -->
        <StackPanel
            Margin="0,0,0,8"
            DockPanel.Dock="Top"
            Orientation="Horizontal">
            <TextBlock
                Width="70"
                VerticalAlignment="Center"
                Text="品目名：" />
            <TextBox
                Name="TxtItemName"
                Width="320"
                Padding="4,2"
                VerticalContentAlignment="Center"
                ToolTip="アプリ上で表示する品目名（初期値はCSVの品目名）" />
        </StackPanel>

        <!--  工程リスト（順序・指示先番号は読み取り専用、工程名・LT・設定は編集可）  -->
        <DataGrid
            Name="ProcessGrid"
            Margin="0,0,0,8"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            HeadersVisibility="Column"
            SelectionMode="Single"
            SelectionUnit="Cell">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="50"
                    Binding="{Binding SortOrder}"
                    Header="順序"
                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#888888" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding ProcessName, UpdateSourceTrigger=PropertyChanged}"
                    Header="工程名（変更可）" />
                <DataGridTextColumn
                    Width="90"
                    Binding="{Binding DestinationCode}"
                    Header="指示先番号"
                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#888888" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn
                    Width="90"
                    Binding="{Binding LeadTimeMinutes, UpdateSourceTrigger=PropertyChanged}"
                    Header="標準時間（分）" />
                <DataGridTextColumn
                    Width="90"
                    Binding="{Binding CoolTimeMinutes, UpdateSourceTrigger=PropertyChanged}"
                    Header="クールタイム（分）" />
                <DataGridTextColumn
                    Width="90"
                    Binding="{Binding OutsourceLeadDays, UpdateSourceTrigger=PropertyChanged}"
                    Header="外注待ち（営業日）" />
                <DataGridCheckBoxColumn
                    Width="45"
                    Binding="{Binding IsVisible, UpdateSourceTrigger=PropertyChanged}"
                    Header="表示" />
                <DataGridTextColumn
                    Width="80"
                    Binding="{Binding WarningDaysBeforeDeadline, UpdateSourceTrigger=PropertyChanged}"
                    Header="警告（日前）" />
                <!--  担当部署コンボボックス列  -->
                <DataGridTemplateColumn Width="110" Header="担当部署">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                Padding="4,0"
                                VerticalAlignment="Center"
                                Text="{Binding DepartmentId, Converter={StaticResource DeptIdToNameConverter}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox
                                DisplayMemberPath="Name"
                                ItemsSource="{Binding Tag, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                SelectedValue="{Binding DepartmentId, UpdateSourceTrigger=PropertyChanged}"
                                SelectedValuePath="Id" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="44" Header="">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button
                                Padding="4,2"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="BtnDeleteRow_Click"
                                Content="✕"
                                FontSize="11"
                                Foreground="#D32F2F" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
    </TabItem>

    <TabItem Header="製品">
    <DockPanel Margin="8">
        <StackPanel
            Margin="0,8,0,0"
            HorizontalAlignment="Right"
            DockPanel.Dock="Bottom"
            Orientation="Horizontal">
            <Button
                Margin="0,0,8,0"
                Padding="8,4"
                Click="BtnAddFinishedProduct_Click"
                Content="追加" />
            <Button
                Margin="0,0,8,0"
                Padding="16,6"
                Background="#1976D2"
                BorderThickness="0"
                Click="BtnSaveFinishedProducts_Click"
                Content="保存"
                Foreground="White" />
            <Button
                Padding="16,6"
                Click="BtnClose_Click"
                Content="閉じる" />
        </StackPanel>
        <TextBlock
            Name="TxtFinishedProductStatus"
            Margin="0,4,0,0"
            DockPanel.Dock="Bottom"
            Foreground="#666666" />

        <TextBlock
            Margin="0,0,0,12"
            DockPanel.Dock="Top"
            FontSize="16"
            FontWeight="Bold"
            Text="製品（品目番号 先頭一致）の登録" />

        <DataGrid
            Name="FinishedProductGrid"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            HeadersVisibility="Column"
            SelectionMode="Single"
            SelectionUnit="Cell">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                    Header="表示名" />
                <DataGridTextColumn
                    Width="200"
                    Binding="{Binding ItemNumberPrefix, UpdateSourceTrigger=PropertyChanged}"
                    Header="品目番号（先頭一致）" />
                <DataGridTemplateColumn Width="44" Header="">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button
                                Padding="4,2"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="BtnDeleteFinishedProductRow_Click"
                                Content="✕"
                                FontSize="11"
                                Foreground="#D32F2F" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
    </TabItem>
    </TabControl>

    <!--  PRONESS取得中のローディングオーバーレイ  -->
    <Grid Name="LoadingOverlay" Visibility="Collapsed" IsHitTestVisible="True">
        <Rectangle Fill="#88000000"/>
        <Border Background="White" CornerRadius="10"
                Width="140" Height="110"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.3"/>
            </Border.Effect>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Ellipse Width="40" Height="40"
                         StrokeThickness="4"
                         StrokeDashArray="6 3"
                         Stroke="#1976D2"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="SpinnerRotate"/>
                    </Ellipse.RenderTransform>
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation
                                        Storyboard.TargetName="SpinnerRotate"
                                        Storyboard.TargetProperty="Angle"
                                        From="0" To="360"
                                        Duration="0:0:0.8"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
                <TextBlock Text="取得中..."
                           Margin="0,10,0,0"
                           HorizontalAlignment="Center"
                           Foreground="#444444"
                           FontSize="13"/>
            </StackPanel>
        </Border>
    </Grid>
    </Grid>
</Window>
